<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Onyx Bar</title>
    <meta name="description" content="Onyx Bar." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body>
    <div class="track">
      <section class="letter"><span>O</span></section>
      <section class="letter"><span>N</span></section>
      <section class="letter"><span>Y</span></section>
      <section class="letter"><span>X</span></section>
    </div>

    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        height: 100%;
        overflow: hidden;
        background: #0a0a0a;
      }
      body {
        color: #ffffff;
        font-family: Georgia, "Times New Roman", serif;
      }
      .track {
        display: flex;
        width: 100vw;
        height: 100vh;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
      }
      .track::-webkit-scrollbar { display: none; }
      .letter {
        flex: 0 0 100vw;
        height: 100vh;
        display: grid;
        place-items: center;
        scroll-snap-align: start;
      }
      .letter span {
        font-size: min(70vh, 70vw);
        font-weight: 900;
        line-height: 1;
        user-select: none;
      }
    </style>

    <script>
      // Translate vertical wheel (mouse users) into horizontal scroll.
      // Trackpad two-finger horizontal + touch swipe already work natively.
      const track = document.querySelector('.track');
      if (track) {
        track.addEventListener('wheel', (e) => {
          if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
            e.preventDefault();
            track.scrollBy({ left: e.deltaY, behavior: 'auto' });
          }
        }, { passive: false });
      }
    </script>
  </body>
</html>
