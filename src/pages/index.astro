<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Onyx Bar</title>
    <meta name="description" content="Onyx Bar." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body>
    <section class="letter"><span>O</span></section>
    <section class="letter"><span>N</span></section>
    <section class="letter"><span>Y</span></section>
    <section class="letter"><span>X</span></section>

    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        scroll-snap-type: y mandatory;
        height: 100%;
      }
      body {
        background: #0a0a0a;
        color: #ffffff;
        font-family: Georgia, "Times New Roman", serif;
        min-height: 100%;
      }
      .letter {
        height: 100vh;
        display: grid;
        place-items: center;
        scroll-snap-align: start;
      }
      .letter span {
        font-size: min(70vh, 70vw);
        font-weight: 900;
        line-height: 1;
        user-select: none;
      }
    </style>
  </body>
</html>
