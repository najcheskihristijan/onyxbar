---
const cocktails = [
  {
    name: "Old Fashioned",
    spirits: "Bourbon",
    build: ["Bourbon", "Demerara sugar", "Angostura bitters", "Orange peel"],
    note: "Stirred. Neat. Unhurried.",
    image: "https://images.unsplash.com/photo-1582056509381-33e11b85733f?w=1600&q=80",
  },
  {
    name: "Negroni",
    spirits: "Gin",
    build: ["Gin", "Campari", "Sweet vermouth", "Orange twist"],
    note: "Bitter, ritualistic.",
    image: "https://images.unsplash.com/photo-1752141930096-ac8292d6a15a?w=1600&q=80",
  },
  {
    name: "Penicillin",
    spirits: "Scotch",
    build: ["Blended Scotch", "Islay float", "Honey-ginger syrup", "Lemon"],
    note: "Smoke on the tongue.",
    image: "https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=1600&q=80",
  },
  {
    name: "Espresso Martini",
    spirits: "Vodka",
    build: ["Vodka", "Fresh espresso", "Coffee liqueur", "Cane sugar"],
    note: "Awake and dressed.",
    image: "https://images.unsplash.com/photo-1678261738794-163c056a1d6f?w=1600&q=80",
  },
  {
    name: "Manhattan",
    spirits: "Rye",
    build: ["Rye whiskey", "Sweet vermouth", "Angostura bitters", "Brandied cherry"],
    note: "The classic, done cold.",
    image: "https://images.unsplash.com/photo-1621873495884-845a939892d1?w=1600&q=80",
  },
  {
    name: "Onyx",
    spirits: "House",
    build: ["Black gin", "Activated charcoal", "Dry vermouth", "Lemon oil"],
    note: "The house signature.",
    image: "https://images.unsplash.com/photo-1693409166438-fc92119a0060?w=1600&q=80",
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Onyx Bar — Menu</title>
    <meta name="description" content="Onyx Bar — cocktail menu." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body>
    <div class="track">
      {cocktails.map((c, i) => (
        <section class="card">
          <img class="bg" src={c.image} alt="" loading={i < 2 ? "eager" : "lazy"} decoding="async" />
          <div class="veil"></div>
          <div class="content">
            <span class="num">{String(i + 1).padStart(2, "0")} / {String(cocktails.length).padStart(2, "0")}</span>
            <span class="spirits">{c.spirits}</span>
            <h1 class="name">{c.name}</h1>
            <ul class="build">
              {c.build.map((line) => <li>{line}</li>)}
            </ul>
            <p class="note">{c.note}</p>
          </div>
        </section>
      ))}
    </div>

    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        height: 100%;
        overflow: hidden;
        background: #0a0a0a;
      }
      body {
        color: #f5f5f5;
        font-family: Georgia, "Times New Roman", serif;
      }
      .track {
        display: flex;
        width: 100vw;
        height: 100vh;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
      }
      .track::-webkit-scrollbar { display: none; }

      .card {
        flex: 0 0 100vw;
        height: 100vh;
        scroll-snap-align: start;
        position: relative;
        overflow: hidden;
      }
      .card .bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: saturate(0.85) brightness(0.75);
      }
      .card .veil {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse at center, rgba(10,10,10,0.2) 0%, rgba(10,10,10,0.55) 60%, rgba(10,10,10,0.85) 100%),
          linear-gradient(to bottom, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0.1) 40%, rgba(10,10,10,0.85) 100%);
      }

      .content {
        position: relative;
        z-index: 1;
        height: 100%;
        padding: 4rem;
        display: grid;
        grid-template-rows: 1fr auto auto auto 1fr;
        place-items: center;
        text-align: center;
      }
      .num {
        position: absolute;
        top: 2rem;
        left: 2rem;
        font-family: ui-monospace, "SF Mono", Menlo, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.2em;
        color: #bbb;
      }
      .spirits {
        position: absolute;
        top: 2rem;
        right: 2rem;
        font-size: 0.85rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #c9a34a;
      }
      .name {
        grid-row: 2;
        font-size: clamp(3rem, 10vw, 8rem);
        font-weight: 400;
        font-style: italic;
        line-height: 1;
        letter-spacing: -0.02em;
        margin: 0;
        text-shadow: 0 2px 40px rgba(0,0,0,0.6);
      }
      .build {
        grid-row: 3;
        list-style: none;
        margin-top: 2rem;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: clamp(0.95rem, 1.5vw, 1.1rem);
        line-height: 2;
        letter-spacing: 0.05em;
        color: #e8e8e8;
        text-shadow: 0 1px 20px rgba(0,0,0,0.7);
      }
      .note {
        grid-row: 4;
        margin-top: 2rem;
        font-style: italic;
        font-size: clamp(0.95rem, 1.4vw, 1.15rem);
        color: #c9c9c9;
        max-width: 30ch;
        text-shadow: 0 1px 20px rgba(0,0,0,0.7);
      }
    </style>

    <script>
      const track = document.querySelector('.track');
      if (track) {
        track.addEventListener('wheel', (e) => {
          if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
            e.preventDefault();
            track.scrollBy({ left: e.deltaY, behavior: 'auto' });
          }
        }, { passive: false });
      }
    </script>
  </body>
</html>
