---
const cocktails = [
  {
    name: "Old Fashioned",
    spirits: "Bourbon",
    build: ["Bourbon", "Demerara sugar", "Angostura bitters", "Orange peel"],
    note: "Stirred. Neat. Unhurried.",
    image: "https://images.unsplash.com/photo-1582056509381-33e11b85733f?w=1000&q=80",
  },
  {
    name: "Negroni",
    spirits: "Gin",
    build: ["Gin", "Campari", "Sweet vermouth", "Orange twist"],
    note: "Bitter, ritualistic.",
    image: "https://images.unsplash.com/photo-1752141930096-ac8292d6a15a?w=1000&q=80",
  },
  {
    name: "Penicillin",
    spirits: "Scotch",
    build: ["Blended Scotch", "Islay float", "Honey-ginger syrup", "Lemon"],
    note: "Smoke on the tongue.",
    image: "https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=1000&q=80",
  },
  {
    name: "Espresso Martini",
    spirits: "Vodka",
    build: ["Vodka", "Fresh espresso", "Coffee liqueur", "Cane sugar"],
    note: "Awake and dressed.",
    image: "https://images.unsplash.com/photo-1678261738794-163c056a1d6f?w=1000&q=80",
  },
  {
    name: "Manhattan",
    spirits: "Rye",
    build: ["Rye whiskey", "Sweet vermouth", "Angostura bitters", "Brandied cherry"],
    note: "The classic, done cold.",
    image: "https://images.unsplash.com/photo-1621873495884-845a939892d1?w=1000&q=80",
  },
  {
    name: "Onyx",
    spirits: "House",
    build: ["Black gin", "Activated charcoal", "Dry vermouth", "Lemon oil"],
    note: "The house signature.",
    image: "https://images.unsplash.com/photo-1693409166438-fc92119a0060?w=1000&q=80",
  },
];

const FIRST_X = 70;  // vw — first item center offset from canvas start
const GAP = 75;      // vw — distance between item centers
const TAIL = 70;     // vw — blank space after the last item
const canvasWidthVw = FIRST_X + (cocktails.length - 1) * GAP + TAIL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Onyx Bar — Menu</title>
    <meta name="description" content="Onyx Bar — cocktail menu." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  </head>
  <body>
    <div class="track" id="track">
      <div class="canvas" style={`width: ${canvasWidthVw}vw;`}>
        {cocktails.map((c, i) => (
          <article class="item" style={`--x: ${FIRST_X + i * GAP}vw;`}>
            <div class="frame">
              <img src={c.image} alt={c.name} loading={i < 2 ? "eager" : "lazy"} decoding="async" />
            </div>
            <div class="text">
              <span class="spirits">{c.spirits}</span>
              <h2 class="name">{c.name}</h2>
              <p class="build">{c.build.join(" · ")}</p>
              <p class="note">{c.note}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="hint">scroll →</div>

    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        height: 100%;
        overflow: hidden;
        background: #0a0a0a;
      }
      body {
        color: #f5f5f5;
        font-family: Georgia, "Times New Roman", serif;
      }

      .track {
        width: 100vw;
        height: 100vh;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        scroll-behavior: auto;
      }
      .track::-webkit-scrollbar { display: none; }

      .canvas {
        position: relative;
        height: 100%;
      }

      .item {
        position: absolute;
        top: 50%;
        left: var(--x);
        transform: translate3d(-50%, -50%, 0) scale(1);
        width: min(34vw, 420px);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.8rem;
        text-align: center;
        will-change: opacity, transform;
        opacity: 0;
        backface-visibility: hidden;
      }
      @media (max-width: 768px) {
        .item { width: 70vw; }
      }

      .frame {
        width: 100%;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        border-radius: 2px;
        position: relative;
        background: #111;
      }
      .frame::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(10,10,10,0.15);
        pointer-events: none;
      }
      .frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .text { display: flex; flex-direction: column; align-items: center; gap: 0.7rem; }
      .spirits {
        font-size: 0.75rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #c9a34a;
      }
      .name {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 400;
        font-style: italic;
        line-height: 1;
        letter-spacing: -0.01em;
      }
      .build {
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        color: #cfcfcf;
      }
      .note {
        font-style: italic;
        font-size: 0.9rem;
        color: #888;
      }

      .hint {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: ui-monospace, "SF Mono", Menlo, monospace;
        font-size: 0.75rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: #666;
        pointer-events: none;
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.8; }
      }
    </style>

    <script>
      const track = document.getElementById('track');
      const items = Array.from(document.querySelectorAll('.item'));
      let ticking = false;

      function update() {
        const vw = window.innerWidth;
        const centerX = track.scrollLeft + vw / 2;
        for (const item of items) {
          const itemCenter = item.offsetLeft; // left + translate(-50%) → offsetLeft is the centre x
          const d = (itemCenter - centerX) / vw; // -1 = one viewport left of center, +1 = one right

          // opacity: fully visible inside ±0.25vw, fades out by ±0.9vw
          const fadeIn = 1 - Math.min(Math.max((Math.abs(d) - 0.25) / 0.65, 0), 1);
          const opacity = Math.pow(fadeIn, 1.4);

          // scale: 0.7 at distance, 1.0 at centre
          const scale = 0.7 + 0.3 * Math.max(0, 1 - Math.abs(d) * 1.1);

          // slight horizontal drift (parallax feel)
          const drift = d * -10; // px, items drift opposite scroll direction a touch

          item.style.opacity = opacity.toFixed(3);
          item.style.transform = `translate3d(calc(-50% + ${drift.toFixed(1)}px), -50%, 0) scale(${scale.toFixed(3)})`;
        }
        ticking = false;
      }

      function request() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      }

      track.addEventListener('scroll', request, { passive: true });
      window.addEventListener('resize', request);

      // Wheel → horizontal (mouse users). Trackpad/touch handle horizontally natively.
      track.addEventListener('wheel', (e) => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          e.preventDefault();
          track.scrollBy({ left: e.deltaY, behavior: 'auto' });
        }
      }, { passive: false });

      // Keyboard arrows
      window.addEventListener('keydown', (e) => {
        const step = window.innerWidth * 0.6;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') track.scrollBy({ left: step, behavior: 'smooth' });
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp')   track.scrollBy({ left: -step, behavior: 'smooth' });
      });

      // Initial paint after layout settles
      requestAnimationFrame(update);
      window.addEventListener('load', update);
    </script>
  </body>
</html>
